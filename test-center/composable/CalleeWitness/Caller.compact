// Cross-calls into the witness-defining Callee. This contract declares no
// witnesses of its own, so it is a normal root contract.

import CompactStandardLibrary;

contract Callee {
  circuit bump(value: Field): Field;
  circuit leak(): Field;
}

export ledger callee: Callee;

constructor(c: Callee) {
  callee = disclose(c);
}

export circuit callBump(value: Field): Field {
  return callee.bump(disclose(value));
}

export circuit callLeak(): Field {
  return callee.leak();
}
