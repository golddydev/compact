// A callee that *declares* a witness. Both circuits are impure (they write the
// ledger), so each is a valid non-pure cross-contract callee — but only `leak`
// actually invokes the witness. Witnesses are available only to the entry (root)
// contract, so `bump` must still run when reached via a cross-contract call while
// `leak` must be rejected.

import CompactStandardLibrary;

export ledger v: Field;

witness secret(): Field;

// Witness-free: writes the ledger, never touches `secret`.
export circuit bump(value: Field): Field {
  v = v + disclose(value);
  return v;
}

// Invokes the witness — must be rejected when reached via a cross-contract call.
export circuit leak(): Field {
  v = v + disclose(secret());
  return v;
}
